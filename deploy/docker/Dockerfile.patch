ARG BASE_IMAGE=docker.1ms.run/unclecode/crawl4ai:latest
FROM ${BASE_IMAGE}

# Patch: fix Chinese characters being escaped (\uXXXX) in JSON output
# Issue: json.dumps() defaults to ensure_ascii=True, which escapes non-ASCII chars

# 1. mcp_bridge.py — MCP tool/resource responses
#    _call_tool:   json.dumps(err)            → json.dumps(err, ensure_ascii=False)
#    _call_tool:   json.dumps(res, default=str) → json.dumps(res, default=str, ensure_ascii=False)
#    _read_resource: json.dumps(res, default=str) → json.dumps(res, default=str, ensure_ascii=False)
RUN sed -i 's/json\.dumps(err)/json.dumps(err, ensure_ascii=False)/g' /app/mcp_bridge.py && \
    sed -i 's/json\.dumps(res, default=str)/json.dumps(res, default=str, ensure_ascii=False)/g' /app/mcp_bridge.py

# 2. api.py — stream_results() NDJSON output
#    json.dumps(result_dict, default=datetime_handler) → ...ensure_ascii=False)
#    json.dumps(error_response)                         → ...ensure_ascii=False)
#    json.dumps({"status": "completed"})                → ...ensure_ascii=False)
RUN sed -i 's/json\.dumps(result_dict, default=datetime_handler)/json.dumps(result_dict, default=datetime_handler, ensure_ascii=False)/g' /app/api.py && \
    sed -i 's/json\.dumps(error_response)/json.dumps(error_response, ensure_ascii=False)/g' /app/api.py && \
    sed -i 's/json\.dumps({"status": "completed"})/json.dumps({"status": "completed"}, ensure_ascii=False)/g' /app/api.py

# 3. mcp_bridge.py — Fix schema generation for FastAPI Query parameters
#    _body_model() only finds Pydantic BaseModel, so endpoints using Query()
#    params (like /ask) get an empty schema {"type":"object"}, causing MCP
#    clients to drop all arguments. Add _query_schema() as fallback.
RUN perl -0777 -i -pe 's/    def _body_model\(fn: Callable\) -> type\[BaseModel\] \| None:\r?\n        for p in inspect\.signature\(fn\)\.parameters\.values\(\):\r?\n            a = p\.annotation\r?\n            if inspect\.isclass\(a\) and issubclass\(a, BaseModel\):\r?\n                return a\r?\n        return None/    def _body_model(fn: Callable) -> type[BaseModel] | None:\n        for p in inspect.signature(fn).parameters.values():\n            a = p.annotation\n            if inspect.isclass(a) and issubclass(a, BaseModel):\n                return a\n        return None\n\n    def _query_schema(fn: Callable) -> dict | None:\n        from fastapi import params as fp\n        import typing as _t\n        props, required = {}, []\n        _tmap = {str: "string", int: "integer", float: "number", bool: "boolean"}\n        for p in inspect.signature(fn).parameters.values():\n            d = p.default\n            if not isinstance(d, (fp.Query, fp.Path)):\n                continue\n            ann = p.annotation\n            if getattr(ann, "__origin__", None) is _t.Union:\n                ann = [a for a in ann.__args__ if a is not type(None)][0]\n            prop = {"type": _tmap.get(ann, "string")}\n            if getattr(d, "description", None):\n                prop["description"] = d.description\n            if d.default is not ...:\n                prop["default"] = d.default\n            else:\n                required.append(p.name)\n            props[p.name] = prop\n        if not props:\n            return None\n        schema = {"type": "object", "properties": props}\n        if required:\n            schema["required"] = required\n        return schema/' /app/mcp_bridge.py && \
    sed -i 's/schema = getattr(orig_fn, "__mcp_schema__", None) or _schema(_body_model(orig_fn))/model = _body_model(orig_fn); schema = getattr(orig_fn, "__mcp_schema__", None) or (_schema(model) if model else _query_schema(orig_fn)) or {"type": "object"}/' /app/mcp_bridge.py
